# Session pooler URI (Supabase > Project Settings > Database > Connection string > "Session pooler").
# Convert scheme to postgresql+asyncpg:// and URL-encode the password.
# Use the SESSION pooler (port 5432), NOT the direct connection (IPv6) or transaction pooler (6543).
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Supabase > Project Settings > API (new-style keys)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_<...>   # client-safe
SUPABASE_SECRET_KEY=sb_secret_<...>             # server-only; never ship to client
# Asymmetric-JWT projects verify tokens via JWKS:
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# HS256 projects instead use a shared secret (leave blank if using JWKS):
SUPABASE_JWT_SECRET=

# App
CORS_ORIGINS=http://localhost:8081,http://localhost:19006   # Expo dev; tighten for prod
ENV=dev
