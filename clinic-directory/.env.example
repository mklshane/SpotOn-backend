# Copy to .env and fill in. .env is gitignored.

# Supabase (same project/credentials as the other collectors).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Google Places (used by 02-collect.py).
GOOGLE_PLACES_API_KEY=your-google-places-key

# Gemini API (used by the enrichment scripts 05-08).
GEMINI_API_KEY=your-gemini-api-key
# Model name kept in config so it can be bumped to a Gemini 3 model later.
# If this key rejects gemini-2.5-flash, try gemini-flash-latest.
GEMINI_MODEL=gemini-2.5-flash
